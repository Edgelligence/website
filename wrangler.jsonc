{
  "name": "edgelligence",
  "compatibility_date": "2026-02-03",
  "assets": {
    "directory": "./dist"
  },
  // D1 Database for subscriber persistence
  // Create with: wrangler d1 create edgelligence-subscribers
  // Deploy with migrations: npm run deploy
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "edgelligence-subscribers",
      "database_id": "8db56eb6-5760-4a39-ae9c-a79512a20b5f",
      "migrations_dir": "migrations"
    }
  ]
  // Note: Set IP_SALT secret via: wrangler secret put IP_SALT
}
